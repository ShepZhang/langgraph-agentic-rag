# Chat LLM provider.
# Options:
# - openai_compatible: OpenAI, DeepSeek, or any OpenAI-compatible remote API.
# - ollama: local Ollama server through its OpenAI-compatible endpoint.
LLM_PROVIDER=openai_compatible
LLM_TEMPERATURE=0

# OpenAI-compatible remote chat LLM.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Local Ollama chat LLM.
# To use it, set LLM_PROVIDER=ollama and install/pull the model locally.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# Embeddings.
# MVP default runs sentence-transformers locally.
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking.
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Retrieval.
TOP_K=4
HYBRID_RETRIEVAL_ENABLED=false
DENSE_TOP_K=20
BM25_TOP_K=20
FUSION_TOP_K=20
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5
RERANKER_CANDIDATE_TOP_K=12
MAX_RETRY_COUNT=2

# Vector store.
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=agentic_rag_documents

# Gradio.
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860

# Trace logging.
TRACE_LOGGING_ENABLED=true
TRACE_LOG_DIR=./data/traces

# FastAPI service layer.
API_UPLOAD_DIR=./uploads/api
API_DOCUMENT_REGISTRY_PATH=./data/api_documents/registry.json
EVALUATION_RUN_DIR=./data/evaluation_runs
